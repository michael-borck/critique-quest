{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "outDir": "../../dist",
    "rootDir": "..",
    "baseUrl": ".",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["**/*", "../core/**/*", "../shared/**/*"],
  "exclude": ["node_modules", "**/*.test.ts", "../core/**/*.test.ts", "../shared/**/*.test.ts"]
}
