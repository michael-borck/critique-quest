{
  "name": "critique-quest",
  "version": "1.0.8",
  "description": "AI-Powered Case Study Generator",
  "main": "dist/main/main.js",
  "homepage": "https://github.com/michael-borck/critique-quest",
  "repository": {
    "type": "git",
    "url": "https://github.com/michael-borck/critique-quest.git"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p src/main && NODE_ENV=development electron dist/main/main.js --no-sandbox",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p src/main",
    "build:renderer": "vite build",
    "build:server": "tsc -p src/server",
    "build:web": "WEB=1 vite build",
    "start:server": "node dist/server/index.js",
    "server": "npm run build:server && npm run build:web && npm run start:server",
    "dist": "electron-builder",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit -p src/main && tsc --noEmit -p src/server && tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "education",
    "ai",
    "case-studies",
    "electron"
  ],
  "author": {
    "name": "Michael Borck",
    "email": "michael@borck.me"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.9.0",
    "@types/react": "^18.2.25",
    "@types/react-dom": "^18.2.11",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^8.2.2",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@mui/icons-material": "^5.14.11",
    "@mui/material": "^5.14.11",
    "axios": "^1.12.0",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9",
    "fastify": "^5.8.5",
    "html-to-text": "^9.0.5",
    "jspdf": "^4.2.1",
    "mammoth": "^1.6.0",
    "node-json-db": "^2.6.0",
    "openai": "^4.104.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "zustand": "^4.4.1"
  },
  "build": {
    "appId": "com.critiquequest.app",
    "productName": "CritiqueQuest",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "michael-borck",
      "repo": "critique-quest"
    },
    "mac": {
      "category": "public.app-category.education",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
